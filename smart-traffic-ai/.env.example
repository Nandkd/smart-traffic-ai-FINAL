# .env.example — copy to .env and fill in values
# ================================================

# Flask
SECRET_KEY=change-this-in-production-use-a-long-random-string
JWT_SECRET_KEY=change-this-jwt-secret-too
FLASK_ENV=development
FLASK_DEBUG=1

# Database (SQLite path auto-generated — no config needed for dev)
# For production, you can switch to PostgreSQL:
# DATABASE_URL=postgresql://user:pass@localhost:5432/trafficai

# ML Models
YOLO_WEIGHTS_PATH=ml_models/weights/yolov8_traffic.pt
CNN_WEIGHTS_PATH=ml_models/weights/ambulance_cnn.pth
ENSEMBLE_PATH=ml_models/weights/congestion_ensemble.pkl

# Camera / RTSP (for production deployment)
RTSP_CAMERA_1=rtsp://admin:password@192.168.1.100:554/stream
RTSP_CAMERA_2=rtsp://admin:password@192.168.1.101:554/stream

# CORS origins (comma-separated for production)
CORS_ORIGINS=http://localhost:5173,https://your-domain.com

# Optional: OpenWeatherMap API for real weather features
WEATHER_API_KEY=your_openweathermap_key_here
